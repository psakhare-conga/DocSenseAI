{
  "name": "docsense-ai",
  "version": "1.0.0",
  "description": "AI-powered document intelligence for Conga contracts — Office Add-in",
  "scripts": {
    "install-certs": "office-addin-dev-certs install --machine",
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "postbuild": "node -e \"const fs=require('fs'); fs.copyFileSync('staticwebapp.config.json','dist/staticwebapp.config.json'); fs.writeFileSync('dist/index.html','<!DOCTYPE html><html><head><meta http-equiv=\\\"refresh\\\" content=\\\"0;url=/taskpane.html\\\"></head></html>');\"",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.365",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "office-addin-dev-certs": "^2.0.7",
    "office-addin-manifest": "^2.1.3",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.2.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}

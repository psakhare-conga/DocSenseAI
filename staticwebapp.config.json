{
  "navigationFallback": {
    "rewrite": "/taskpane.html",
    "exclude": ["/*.{js,css,png,ico,html}", "/assets/*"]
  },
  "mimeTypes": {
    ".xml": "application/xml"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Content-Security-Policy": "frame-ancestors 'self' https://*.officeapps.live.com https://*.microsoft.com https://www.office.com https://res.cdn.office.net",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
